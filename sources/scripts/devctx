#!/usr/bin/env bash
# devctx - Open a development context (project) in kitty + zellij
#
# Scans project directories for git repos and worktrees, lets you pick one
# via rofi, and opens a kitty window with a zellij session in that directory.
#
# Usage: devctx
# Typically bound to an i3 keybinding.

set -euo pipefail

SEARCH_ROOT="$HOME"
MAX_DEPTH=5

# Find all git repos recursively under $HOME.
# Prune hidden dirs (except .git itself) and node_modules for speed.
mapfile -t git_matches < <(
    find "$SEARCH_ROOT" -maxdepth "$MAX_DEPTH" \
        \( -name '.*' ! -name '.git' -o -name 'node_modules' \) -prune \
        -o -name '.git' \( -type d -o -type f \) -print 2>/dev/null
)

candidates=()
for match in "${git_matches[@]}"; do
    candidates+=("$(dirname "$match")/")
done

if [[ ${#candidates[@]} -eq 0 ]]; then
    notify-send "devctx" "No projects found"
    exit 1
fi

# Format for display: show relative to home
display=()
for c in "${candidates[@]}"; do
    display+=("${c/#$HOME\//~/}")
done

# Pick via rofi
selected=$(printf '%s\n' "${display[@]}" | rofi -dmenu -p "project" -i)
[[ -z "$selected" ]] && exit 0

# Expand ~ back
target="${selected/#\~/$HOME}"

# Open kitty with zellij session (unset ZELLIJ so it doesn't attach to parent)
# Delete dead sessions to avoid broken resurrection
session_name=$(basename "$target")
zellij delete-session "$session_name" 2>/dev/null || true
# Attach to live session, or create new one with dev layout
if zellij list-sessions -s 2>/dev/null | grep -qx "${session_name}"; then
    env -u ZELLIJ kitty --directory "$target" --title "dev: $session_name" \
        zellij attach "$session_name" 2>/dev/null &
else
    env -u ZELLIJ kitty --directory "$target" --title "dev: $session_name" \
        zellij -n dev -s "$session_name" 2>/dev/null &
fi

disown
